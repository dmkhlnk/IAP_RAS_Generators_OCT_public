# Project ALPHA EVOLVE - Environment Variables Configuration
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp env.example .env
# 2. Edit .env and insert your actual API key
# 3. The .env file is automatically ignored by git (in .gitignore)
#
# IMPORTANT: Never commit your .env file to git!

# ============================================================================
# REQUIRED: Gemini API Configuration
# ============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# This key is required for AI validation and generation features
GEMINI_API_KEY=your_gemini_api_key_here

# Alternative variable name (for compatibility)
# Some scripts may use GOOGLE_API_KEY instead of GEMINI_API_KEY
GOOGLE_API_KEY=your_gemini_api_key_here

# ============================================================================
# OPTIONAL: Server Configuration (for remote deployment)
# ============================================================================
REMOTE_HOST=your.server.host
REMOTE_USER=your_username
REMOTE_PROJECT_DIR=/home/your_username/alpha_evolve

# ============================================================================
# OPTIONAL: Git Configuration (for automated deployment)
# ============================================================================
GIT_REPO=git@github.com:your_username/your_repo.git

# ============================================================================
# OPTIONAL: Evolution Configuration
# ============================================================================
DEFAULT_GENERATION=1
SESSION_NAME=alpha_evolve_session

# ============================================================================
# API Server Authentication (for remote access)
# ============================================================================
# Set AUTH_ENABLED=false to disable authentication (not recommended for production)
AUTH_ENABLED=true

# Admin credentials for API server login
# If ADMIN_PASSWORD is not set, a random password will be generated on first startup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# Session secret key (auto-generated if not set)
# SESSION_SECRET_KEY=your_secret_key_here

# ============================================================================
# SSL/HTTPS Configuration (optional)
# ============================================================================
# Paths to SSL certificate files (for HTTPS)
# Generate certificates with: python3 api_server/generate_ssl_cert.py
# SSL_KEYFILE=api_server/server.key
# SSL_CERTFILE=api_server/server.crt
